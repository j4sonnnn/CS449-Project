<Window x:Class="SolitaireSprint0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sprint 0" Height="220" Width="360">
    <StackPanel Margin="14">

        <TextBlock Text="Sprint #0 GUI Demo"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- lines -->
        <Canvas Height="18" Margin="0,0,0,10">
            <Line X1="0" Y1="2"  X2="320" Y2="2"  Stroke="Black" StrokeThickness="1"/>
            <Line X1="0" Y1="14" X2="320" Y2="14" Stroke="Black" StrokeThickness="1"/>
        </Canvas>

        <CheckBox x:Name="chkShowPopup" Content="Show popup" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <RadioButton x:Name="rbA" Content="A" IsChecked="True" Margin="0,0,10,0"/>
            <RadioButton x:Name="rbB" Content="B"/>
        </StackPanel>

        <Button Content="Run" Width="90" Click="Run_Click"/>
        <TextBlock x:Name="txtStatus" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
