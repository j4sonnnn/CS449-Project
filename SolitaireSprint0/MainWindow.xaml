<Window x:Class="SolitaireSprint0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solitaire Sprint 2" Height="560" Width="560">
    <DockPanel Margin="12">

        <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Size:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbSize" Width="80" Margin="0,0,14,0"/>

                <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbType" Width="120" Margin="0,0,14,0"/>

                <Button Content="New Game" Width="110" Click="NewGame_Click" Margin="0,0,14,0"/>
                <TextBlock x:Name="txtStatus" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="boardGrid"/>
        </ScrollViewer>

    </DockPanel>
</Window>