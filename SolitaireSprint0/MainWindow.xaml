<Window x:Class="SolitaireSprint0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solitaire" Height="520" Width="520">
    <DockPanel Margin="12">
        <!-- Top controls -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Size:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="cmbSize" Width="70" Margin="0,0,12,0"/>

            <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="cmbType" Width="120" Margin="0,0,12,0"/>

            <Button Content="New Game" Width="90" Click="NewGame_Click" Margin="0,0,12,0"/>
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Board -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="boardGrid"/>
        </ScrollViewer>
    </DockPanel>
</Window>